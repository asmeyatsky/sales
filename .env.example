# Database
SCOUT_DATABASE_URL=sqlite+aiosqlite:///./scout.db

# GCP / Vertex AI
SCOUT_GCP_PROJECT_ID=your-gcp-project-id
SCOUT_GCP_LOCATION=us-central1
SCOUT_VERTEX_AI_MODEL=gemini-1.5-pro

# LinkedIn Sales Navigator
SCOUT_LINKEDIN_API_KEY=your-linkedin-api-key
SCOUT_LINKEDIN_API_SECRET=your-linkedin-api-secret

# Contact Enrichment
SCOUT_APOLLO_API_KEY=your-apollo-api-key
SCOUT_ZOOMINFO_API_KEY=your-zoominfo-api-key

# Email (Gmail)
SCOUT_GMAIL_CREDENTIALS_PATH=./credentials/gmail.json
SCOUT_SENDER_EMAIL=scout@searce.com
SCOUT_SENDER_NAME=Searce Scout

# CRM
SCOUT_CRM_PROVIDER=salesforce
SCOUT_SALESFORCE_CLIENT_ID=your-sf-client-id
SCOUT_SALESFORCE_CLIENT_SECRET=your-sf-client-secret
SCOUT_SALESFORCE_INSTANCE_URL=https://your-instance.salesforce.com
SCOUT_HUBSPOT_API_KEY=your-hubspot-api-key

# Google Slides
SCOUT_SLIDES_TEMPLATE_ID=your-google-slides-template-id
SCOUT_GOOGLE_CREDENTIALS_PATH=./credentials/google.json

# Outreach Defaults
SCOUT_DEFAULT_TONE=PROFESSIONAL_CONSULTANT
SCOUT_STEP_DELAYS_HOURS=[0,48,72,96,120]
SCOUT_BUSINESS_HOURS_START=9
SCOUT_BUSINESS_HOURS_END=17

# Rate Limiting
SCOUT_MAX_CONCURRENT_RESEARCH=3
SCOUT_MAX_CONCURRENT_OUTREACH=5

# API Authentication
SCOUT_API_KEY=your-api-key-here

# CORS Allowed Origins (JSON list)
SCOUT_ALLOWED_ORIGINS=[]
